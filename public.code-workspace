{
  "folders": [
    {
      "path": ".",
    },
    {
      "path": "./template_hp_static",
    },
    {
      "path": "./lint_tools",
    },
  ],
  "settings": {
    "stylelint.stylelintPath": "./lint_tools/node_modules/stylelint",

    "stylelint.validate": ["scss", "css", "postcss"],
    "editor.codeActionsOnSave": {
      "source.fixAll.stylelint": "explicit",
    },
    "liveServer.settings.multiRootWorkspaceName": "template_hp_static",
  },
}
